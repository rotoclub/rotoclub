<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
    <record id="seq_agora_server" model="ir.sequence">
        <field name="name">Agora Server</field>
        <field name="code">agora.server</field>
        <field name="prefix">SERV-AG/%(y)s/%(month)s/</field>
        <field name="padding">5</field>
        <field name="company_id" eval="False"/>
    </record>

    <record id="seq_agora_api" model="ir.sequence">
        <field name="name">Server API</field>
        <field name="code">agora.api</field>
        <field name="prefix">SERV-API/%(y)s/%(month)s/</field>
        <field name="padding">5</field>
        <field name="company_id" eval="False"/>
    </record>

    <record id="seq_sale_api" model="ir.sequence">
        <field name="name">Sale API</field>
        <field name="code">sale.api</field>
        <field name="prefix">SA/%(y)s/%(month)s/</field>
        <field name="padding">5</field>
        <field name="company_id" eval="False"/>
    </record>

